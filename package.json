{
  "name": "timebubble",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "license": "MIT",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android:staging": "eas build -p android --profile preview --local",
    "build:android:production": "eas build -p android --profile production --local",
    "build:ios:staging": "eas build -p ios --profile preview --local",
    "build:ios:production": "eas build -p ios --profile production --local",
    "publish:staging": "eas update --branch preview --message \"Updating the app\" --platform android && eas update --branch preview --message \"Updating the app\" --platform ios",
    "publish:production": "eas update --branch production --message \"Updating over the air P\" --platform android && eas update --branch production --message \"Updating over the air P\" --platform ios"
  },
  "dependencies": {
    "@eva-design/eva": "^2.1.1",
    "@faker-js/faker": "^10.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/stack": "^7.4.2",
    "@ui-kitten/components": "^5.1.2",
    "expo": "^54.0.0",
    "expo-asset": "~12.0.9",
    "expo-build-properties": "~1.0.9",
    "expo-camera": "~17.0.8",
    "expo-clipboard": "~8.0.7",
    "expo-constants": "~18.0.9",
    "expo-device": "~8.0.8",
    "expo-font": "~14.0.8",
    "expo-image-picker": "~17.0.8",
    "expo-linking": "~8.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.7",
    "expo-notifications": "~0.32.11",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "expo-updates": "~29.0.11",
    "lottie-react-native": "~7.3.1",
    "moment": "^2.29.1",
    "pluralize": "^8.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-animatable": "^1.3.3",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-iphone-x-helper": "^1.3.1",
    "react-native-maps": "1.20.1",
    "react-native-masked-text": "^1.13.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-snap-carousel": "github:israelouteiro/react-native-snap-carousel",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.1.1",
    "react-native-worklets": "0.5.1",
    "reanimated-color-picker": "./reanimated-color-picker-4.2.0.tgz",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-plugin-module-resolver": "^5.0.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@ui-kitten/components",
          "react-native-confetti-cannon",
          "react-native-iphone-x-helper",
          "react-native-masked-text",
          "react-native-snap-carousel"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
