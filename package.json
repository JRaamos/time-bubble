{
  "name": "timebubble",
  "version": "1.0.0",
  "author": "Jonathan Febraio",
  "main": "expo/AppEntry.js",
  "license": "MIT",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android:staging": "eas build -p android --profile preview --local",
    "build:android:production": "eas build -p android --profile production --local",
    "build:ios:staging": "eas build -p ios --profile preview --local",
    "build:ios:production": "eas build -p ios --profile production --local",
    "publish:staging": "eas update --branch preview --message \"Updating the app\" --platform android && eas update --branch preview --message \"Updating the app\" --platform ios",
    "publish:production": "eas update --branch production --message \"Updating over the air P\" --platform android && eas update --branch production --message \"Updating over the air P\" --platform ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/native-stack": "^7.3.21",
    "expo": "^54.0.0",
    "expo-build-properties": "~1.0.9",
    "expo-clipboard": "^55.0.9",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.7",
    "expo-updates": "~29.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-iphone-x-helper": "^1.3.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "reanimated-color-picker": "./reanimated-color-picker-4.2.0.tgz",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-plugin-module-resolver": "^5.0.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-iphone-x-helper"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
